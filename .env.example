# ---------- App ----------
APP_ENV=local

# ---------- Ollama ----------
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen3.5:9b

# ---------- Qdrant ----------
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=delivery_docs

# ---------- Embeddings ----------
# "auto" lets the app pick cuda if available
EMBEDDINGS_DEVICE=auto

DEBUGPY=0

# ---------- Retrieval ----------
# auto = project->mmr, external->hybrid
RETRIEVAL_MODE=auto
RETRIEVAL_K=6
MMR_FETCH_K=24
MMR_LAMBDA=0.5
HYBRID_FETCH_K=24
# External-scope candidate depth tuning for hybrid retrieval.
HYBRID_FETCH_K_EXTERNAL_MIN=60
HYBRID_FETCH_K_EXTERNAL_MULTIPLIER=5
HYBRID_FETCH_K_EXTERNAL_MAX=120
HYBRID_ALPHA=0.7
# Optional scope-specific overrides (used when RETRIEVAL_MODE=auto)
HYBRID_ALPHA_PROJECT=0.7
HYBRID_ALPHA_EXTERNAL=0.45
HYBRID_ALPHA_ALL=0.65
SIMILARITY_FETCH_K=24

# ---------- Groundedness gates ----------
# Lower score means closer match (cosine distance in Qdrant).
GROUNDEDNESS_MIN_SCORE_PROJECT=0.65
GROUNDEDNESS_MIN_SCORE_EXTERNAL=0.80
GROUNDEDNESS_MIN_SCORE_ALL=0.75

# ---------- Generation ----------
ASK_TEMPERATURE=0.1

# ---------- Document Scope ----------
# project (default) | external | all
DOC_SCOPE=project

# ---------- UI ----------
# Optional: only needed if you run Streamlit outside docker
API_URL=http://api:8000

# ---------- Langfuse (SDK in API) ----------
# If empty, tracing auto-disables.
LANGFUSE_HOST=http://langfuse-web:3000
LANGFUSE_BASE_URL=http://langfuse-web:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ---------- Langfuse v3 infra ----------
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=changeme
SALT=changeme
ENCRYPTION_KEY=changeme

LANGFUSE_DATABASE_URL=postgresql://langfuse:langfuse@postgres:5432/langfuse

CLICKHOUSE_URL=http://clickhouse:8123
CLICKHOUSE_MIGRATION_URL=clickhouse://clickhouse:9000
CLICKHOUSE_USER=clickhouse
CLICKHOUSE_PASSWORD=clickhouse
CLICKHOUSE_DB=default
CLICKHOUSE_CLUSTER_ENABLED=false

REDIS_CONNECTION_STRING=redis://valkey:6379/0

MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123456

LANGFUSE_S3_EVENT_UPLOAD_BUCKET=langfuse-events
LANGFUSE_S3_EVENT_UPLOAD_REGION=us-east-1
LANGFUSE_S3_EVENT_UPLOAD_ENDPOINT=http://minio:9000
LANGFUSE_S3_EVENT_UPLOAD_ACCESS_KEY_ID=minio
LANGFUSE_S3_EVENT_UPLOAD_SECRET_ACCESS_KEY=minio123456
LANGFUSE_S3_EVENT_UPLOAD_FORCE_PATH_STYLE=true

LANGFUSE_S3_MEDIA_UPLOAD_BUCKET=langfuse-media
LANGFUSE_S3_MEDIA_UPLOAD_REGION=us-east-1
LANGFUSE_S3_MEDIA_UPLOAD_ENDPOINT=http://minio:9000
LANGFUSE_S3_MEDIA_UPLOAD_ACCESS_KEY_ID=minio
LANGFUSE_S3_MEDIA_UPLOAD_SECRET_ACCESS_KEY=minio123456
LANGFUSE_S3_MEDIA_UPLOAD_FORCE_PATH_STYLE=true
